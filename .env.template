# ============================================
# 排班管理系统 - 环境变量配置模板
# ============================================
# 请复制此文件为 .env 并填入实际值
# cp .env.template .env
# ============================================

# --------------------------------------------
# 飞书应用配置 (必填)
# --------------------------------------------
# 1. 访问 https://open.feishu.cn/app
# 2. 创建企业自建应用
# 3. 在"凭证与基础信息"页面获取

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 事件订阅加密密钥 (可选，用于飞书回调验证)
FEISHU_ENCRYPT_KEY=

# 事件订阅验证令牌 (可选，用于飞书回调验证)
FEISHU_VERIFICATION_TOKEN=

# --------------------------------------------
# 多维表格配置 (必填)
# --------------------------------------------
# 1. 打开飞书多维表格
# 2. 从浏览器地址栏获取 token：
#    https://xxx.feishu.cn/base/xxxxxxxxxxxxx
#                              ↑ 这部分就是 BITABLE_APP_TOKEN

BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxx

# 数据表 ID (从表设置中获取，格式如: tblxxxxxxxxxxxxxx)
# 如果不填，系统会使用默认 ID，需要在代码中修改
STORE_TABLE_ID=tblStore
EMPLOYEE_TABLE_ID=tblEmployee
SCHEDULE_TABLE_ID=tblSchedule

# --------------------------------------------
# 服务器配置
# --------------------------------------------
PORT=3000
NODE_ENV=production

# --------------------------------------------
# 邮件配置 (用于发送排班通知)
# --------------------------------------------
# 方式1: 飞书企业邮箱
SMTP_HOST=smtp.feishu.cn
SMTP_PORT=587

# 方式2: 阿里云邮件推送
# SMTP_HOST=smtpdm.aliyun.com
# SMTP_PORT=465

# 方式3: 腾讯企业邮箱
# SMTP_HOST=smtp.exmail.qq.com
# SMTP_PORT=465

SMTP_USER=your_email@company.com
SMTP_PASS=your_email_password_or_smtp_key

# 管理员邮箱 (用于接收系统通知)
ADMIN_EMAIL=admin@company.com

# --------------------------------------------
# 可选配置
# --------------------------------------------

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 请求超时时间 (毫秒)
REQUEST_TIMEOUT=30000

# 会话密钥 (用于加密会话，随机生成)
SESSION_SECRET=your_random_session_secret_key

# --------------------------------------------
# 配置示例 (请删除这些示例)
